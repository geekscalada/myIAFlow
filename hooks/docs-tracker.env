# docs-tracker.env
# Configuration for the docs-tracker PostToolUse hook.
#
# TRACKED_PATHS: space-separated list of path prefixes to monitor.
#   The hook will fire for any tool that reads a file whose path
#   starts with one of these prefixes (trailing slash optional).
#
# LOG_FILE: where to write the persistent plain-text log.
#   Defaults to /tmp/docs-tracker.log if not set.

TRACKED_PATHS="/docs /files"
LOG_FILE="/tmp/docs-tracker.log"
